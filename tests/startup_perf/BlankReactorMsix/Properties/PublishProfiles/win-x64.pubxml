<?xml version="1.0" encoding="utf-8"?>
<!--
    Publish profile consumed by VS's `Create App Packages` wizard for the x64
    target. Without a pubxml in this folder the wizard reports "no valid
    configuration found" because it has no `Publish target → RID` triplet to
    populate. Mirrors the layout the standard WinAppSDK single-project MSIX
    template emits. Properties intentionally minimal — anything not set here
    falls through to the csproj defaults so the command-line build flow used
    by CI (which never reads this file) keeps its existing semantics.

    A corresponding `<PublishProfile>` reference in BlankReactor.csproj picks
    this file (or the arm64 sibling) by `$(Platform)` during publish.
-->
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishDir>bin\publish\win-x64\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>
    <TargetFramework>net10.0-windows10.0.22621.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>False</PublishSingleFile>
    <PublishReadyToRun>False</PublishReadyToRun>
  </PropertyGroup>
</Project>
