<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tp="using:Reactor.AppTests.ThirdPartyControls">

    <Style TargetType="tp:ThirdPartyControlWithPrivateDp">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="tp:ThirdPartyControlWithPrivateDp">
                    <Border>
                        <TextBlock Text="{TemplateBinding MyText}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
