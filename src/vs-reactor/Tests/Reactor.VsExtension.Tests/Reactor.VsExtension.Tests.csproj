<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- See Reactor.VsExtension.csproj for the TF_BUILD (Azure DevOps / OneBranch)
         guard rationale: inert net10.0 on OB, full net472 VSIX-test project elsewhere. -->
    <TargetFramework Condition="'$(TF_BUILD)' != 'true'">net472</TargetFramework>
    <TargetFramework Condition="'$(TF_BUILD)' == 'true'">net10.0</TargetFramework>
    <UseWPF Condition="'$(TF_BUILD)' != 'true'">true</UseWPF>
    <EnableDefaultItems Condition="'$(TF_BUILD)' == 'true'">false</EnableDefaultItems>
    <EnableDefaultCompileItems Condition="'$(TF_BUILD)' == 'true'">false</EnableDefaultCompileItems>
    <LangVersion>latest</LangVersion>
    <IsAotCompatible>false</IsAotCompatible>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);IL2026;IL3050;IL2104;IL2118;CS2008</NoWarn>
  </PropertyGroup>

  <ItemGroup Condition="'$(TF_BUILD)' != 'true'">
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.8.0" />
    <PackageReference Include="System.Text.Json" Version="9.0.0" />
    <PackageReference Include="xunit" Version="2.5.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.5.3" PrivateAssets="all" IncludeAssets="runtime; build; native; contentfiles; analyzers; buildtransitive" />
  </ItemGroup>

  <ItemGroup Condition="'$(TF_BUILD)' != 'true'">
    <ProjectReference Include="..\..\Reactor.VsExtension\Reactor.VsExtension.csproj" ReferenceOutputAssembly="true" CopyLocalSatelliteAssemblies="false" PrivateAssets="all" />
  </ItemGroup>
</Project>
