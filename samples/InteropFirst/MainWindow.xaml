<Window
    x:Class="InteropFirst.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:InteropFirst.Models"
    Title="Reactor — Interop-first sample (spec 033 §7)">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Interop-first sample" FontSize="28" FontWeight="Bold" />
            <TextBlock Text="Left: XAML ListView. Right: Reactor OrdersDataGrid. Same ObservableCollection, same ICommands."
                       Foreground="{StaticResource SubtleSampleBrush}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="8" Padding="12"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="XAML side (ListView)"
                               Foreground="{StaticResource AccentSampleBrush}"
                               FontWeight="SemiBold" />

                    <ListView x:Name="XamlOrdersList" Grid.Row="1"
                              SelectionMode="Single"
                              SelectionChanged="OnXamlSelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Order">
                                <Grid ColumnSpacing="12" Padding="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind Id}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind CustomerName}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind Amount}"
                                               Foreground="{StaticResource SubtleSampleBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="1" CornerRadius="8" Padding="12"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Reactor side (OrdersDataGrid)"
                               Foreground="{StaticResource AccentSampleBrush}"
                               FontWeight="SemiBold" />
                    <!--
                        ReactorHostControl is constructed in code-behind and assigned
                        to this Border's Child. Doing so in markup trips the WinAppSDK
                        2.0-preview XAML compiler; this is the same pattern used by
                        samples/ReactorHostControlDemo.
                    -->
                    <Border x:Name="ReactorHostContainer" Grid.Row="1" />
                </Grid>
            </Border>
        </Grid>

        <CommandBar Grid.Row="2" DefaultLabelPosition="Right" IsOpen="False" HorizontalAlignment="Stretch">
            <AppBarButton x:Name="AddButton" Label="Add" Icon="Add" Click="OnAddClicked" />
            <AppBarButton x:Name="DeleteButton" Label="Delete" Icon="Delete" Click="OnDeleteClicked" />
        </CommandBar>
    </Grid>

</Window>
