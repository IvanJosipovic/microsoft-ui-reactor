<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.22621.0</TargetFramework>
    <Platforms>x64;ARM64</Platforms>
    <RootNamespace>ChatSample.App</RootNamespace>
    <AssemblyName>ChatSample</AssemblyName>
    <Product>Chat Sample</Product>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
    <UseWinUI>true</UseWinUI>
    <WindowsPackageType>None</WindowsPackageType>
    <ApplicationIcon>Assets\chat.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="$(WindowsAppSDKVersion)" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\src\Reactor\Reactor.csproj" />
    <ProjectReference Include="..\Chat.Model\Chat.Model.csproj" />
    <ProjectReference Include="..\Chat.UI\Chat.UI.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\chat.ico" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
